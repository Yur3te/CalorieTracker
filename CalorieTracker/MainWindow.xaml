<Window x:Class="CalorieTracker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CalorieTracker"
        mc:Ignorable="d"
        Title="MainWindow" Height="750" Width="1350">
   <Grid>
    <Grid.RowDefinitions>
        <RowDefinition Height="50"/> <RowDefinition Height="*"/>  </Grid.RowDefinitions>

    <Border Grid.Row="0" Background="#3F51B5" Padding="10,0">
        <Grid>
            <TextBlock Text="Calorie Tracker 3000" Foreground="White" VerticalAlignment="Center" FontWeight="Bold" FontSize="16"/>
            <Button x:Name="LogoutButton" Content="LOGOUT" HorizontalAlignment="Right" VerticalAlignment="Center" 
                    Padding="10,5" Background="#F44336" Foreground="White" BorderThickness="0" Click="LogoutButton_Click"/>
        </Grid>
    </Border>

    <TabControl Grid.Row="1">
        <TabItem Header="Daily Tracking">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,10">

                        <Grid Margin="0,0,0,10">
                            <TextBlock Text="Daily Journal" FontWeight="Bold" FontSize="16" VerticalAlignment="Center"/>
                            <DatePicker x:Name="MainDatePicker" HorizontalAlignment="Right" Width="150" SelectedDateChanged="MainDatePicker_SelectedDateChanged"/>
                        </Grid>

                        <DataGrid x:Name="MealsDataGrid" AutoGenerateColumns="False" Height="360" IsReadOnly="True" HorizontalAlignment="Stretch">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Product" Binding="{Binding Product}" Width="*"/>
                                <DataGridTextColumn Header="Weight (g)" Binding="{Binding Weight}" Width="100"/>
                                <DataGridTextColumn Header="Calories" Binding="{Binding CaloriesCalculated}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                            <TextBlock Text="Total Calories for this day: " FontSize="14" FontWeight="Bold"/>
                            <TextBlock x:Name="TotalCaloriesText" Text="0" FontSize="14" FontWeight="Bold" Foreground="#3F51B5"/>
                        </StackPanel>
                        
                    </StackPanel>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="DeleteMealButton" Content="DELETE SELECTED" Background="#E91E63" Foreground="White" Width="160" Height="40" Margin="0,0,10,0" Click="DeleteMealButton_Click"/>
                        <Button x:Name="EditMealButton" Content="EDIT" Background="#FF9800" Foreground="White" Width="100" Height="40" Margin="0,0,10,0" Click="EditMealButton_Click"/>
                        <Button x:Name="AddMealButton" Content="ADD NEW" Background="#4CAF50" Foreground="White" Width="120" Height="40" Click="AddMealButton_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

        <TabItem Header="Product Manager">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <DataGrid x:Name="ProductsDataGrid" AutoGenerateColumns="False" IsReadOnly="True" Height="320" Margin="0,0,0,10">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Product Name" Binding="{Binding Name}" Width="*"/>
                                <DataGridTextColumn Header="Kcal (per 100g)" Binding="{Binding CaloriesPer100g}" Width="120"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        <Button x:Name="DeleteProductButton" Content="DELETE SELECTED" Background="#E91E63" Foreground="White" Width="150" HorizontalAlignment="Left" Click="DeleteProductButton_Click"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Add New Product" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>

                        <TextBlock Text="Product Name:"/>
                        <TextBox x:Name="NewProductNameTextBox" Margin="0,0,0,10" Padding="5"/>

                        <TextBlock Text="Calories per 100g:"/>
                        <TextBox x:Name="NewProductKcalTextBox" Margin="0,0,0,20" Padding="5"/>

                        <Button x:Name="AddProductButton" Content="ADD TO DATABASE" Background="#4CAF50" Foreground="White" Height="40" Click="AddProductButton_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="AI Coach">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,20">
                        <TextBlock Text="Select Date to Analyze:" VerticalAlignment="Center" FontWeight="Bold" FontSize="14" Margin="0,0,10,0"/>
                        <DatePicker x:Name="AiDatePicker" Width="150" Margin="0,0,20,0"/>
                        <Button x:Name="AskAiButton" Content="ROAST MY DIET" Background="#673AB7" Foreground="White" FontWeight="Bold" Width="150" Height="35" Click="AskAiButton_Click"/>
                    </StackPanel>

                    <Border Grid.Row="1" Background="#F5F5F5" BorderBrush="Gray" BorderThickness="1" CornerRadius="5" Padding="15">
                        <ScrollViewer>
                            <TextBlock x:Name="AiResponseTextBlock" Text="Select a date and click the button to get roasted by your personal AI coach..." 
                           TextWrapping="Wrap" FontSize="16" FontStyle="Italic" Foreground="#333333"/>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabItem>
        
        </TabControl>
</Grid>
</Window>
