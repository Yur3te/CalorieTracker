<Window x:Class="CalorieTracker.LoginWindow"
        Style="{StaticResource MaterialDesignWindow}"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CalorieTracker"
        mc:Ignorable="d"
        Title="LoginWindow" Height="450" Width="800">
    <Grid>
        <StackPanel Width="200" VerticalAlignment="Center">
            <TextBlock Text="Please log in" FontWeight="Bold" FontSize="16" Margin="0,0,0,20" HorizontalAlignment="Center"/>

            <TextBlock Text="Login:"/>
            <TextBox x:Name="LoginTextBox" Margin="0,0,0,10"/>

            <TextBlock Text="Password:"/>
            <PasswordBox x:Name="PasswordTextBox" Margin="0,0,0,20"/>

            <Button x:Name="BtnLogin" Content="Log in" Height="30" Click="BtnLogin_Click"/>
        </StackPanel>
    </Grid>
</Window>
