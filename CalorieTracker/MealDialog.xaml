<Window x:Class="CalorieTracker.MealDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Meal Details" Height="350" Width="300" WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="Date:" FontWeight="Bold" Margin="0,0,0,5"/>
            <DatePicker x:Name="MealDatePicker" Margin="0,0,0,15" Padding="5"/>
            
            <TextBlock Text="Select Product:" FontWeight="Bold" Margin="0,0,0,5"/>
            <ComboBox x:Name="ProductsComboBox" DisplayMemberPath="Name" SelectedValuePath="Id" IsEditable="True" Margin="0,0,0,15" Padding="5"/>

            <TextBlock Text="Weight:" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="WeightTextBox" Margin="0,0,0,25" Padding="5"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="CANCEL" Background="Gray" Foreground="White" Height="35" Click="CancelButton_Click"/>
                <Button Grid.Column="2" Content="SAVE" Background="#4CAF50" Foreground="White" Height="35" Click="SaveButton_Click"/>
            </Grid>
        </StackPanel>
    </Grid>
</Window>